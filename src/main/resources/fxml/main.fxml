<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.javarpa.controller.MainController"
            stylesheets="@../css/dark-theme.css"
            styleClass="root-pane"
            prefWidth="920" prefHeight="680">

    <!-- TOP HEADER -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="12">
            <Label text="🤖" styleClass="header-logo"/>
            <VBox spacing="0">
                <Label text="JavaRPA Tool" styleClass="header-title"/>
                <Label fx:id="labelStatus" text="● Sẵn sàng" styleClass="status-idle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="labelLicense" text="⚠ Chưa kích hoạt" styleClass="license-warn"/>
            <Label fx:id="labelTime" text="00:00:00" styleClass="header-clock"/>
        </HBox>
    </top>

    <!-- CENTER CONTENT with TabPane -->
    <center>
        <TabPane fx:id="mainTabPane" styleClass="main-tabs" tabClosingPolicy="UNAVAILABLE">

            <!-- TAB: Dashboard -->
            <Tab text="📊 Dashboard" fx:id="tabDashboard">
                <ScrollPane fitToWidth="true" styleClass="scroll-dark">
                    <VBox spacing="16" styleClass="tab-content">

                        <!-- Task Status Card -->
                        <VBox styleClass="card">
                            <Label text="Trạng thái Task" styleClass="card-title"/>
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="Task:" styleClass="label-muted"/>
                                        <Label fx:id="labelTaskName" text="Không có task" styleClass="label-value"/>
                                    </HBox>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="Lặp lại:" styleClass="label-muted"/>
                                        <Label fx:id="labelLoop" text="0 / 0" styleClass="label-value"/>
                                    </HBox>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="Thời gian:" styleClass="label-muted"/>
                                        <Label fx:id="labelElapsed" text="00:00:00" styleClass="label-value"/>
                                    </HBox>
                                    <ProgressBar fx:id="progressTask" progress="0" styleClass="progress-rpa" maxWidth="Infinity"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Screen Monitor Card -->
                        <VBox styleClass="card">
                            <Label text="Screen Monitor" styleClass="card-title"/>
                            <HBox spacing="16">
                                <VBox spacing="8" HBox.hgrow="SOMETIMES" minWidth="200">
                                    <Label text="Tọa độ chuột:" styleClass="label-muted"/>
                                    <Label fx:id="labelMousePos" text="X: 0, Y: 0" styleClass="label-mono"/>
                                    <Label text="Màu pixel:" styleClass="label-muted"/>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Pane fx:id="pixelColorBox" styleClass="pixel-box" prefWidth="20" prefHeight="20"/>
                                        <Label fx:id="labelPixelColor" text="#000000" styleClass="label-mono"/>
                                    </HBox>
                                    <Label text="OCR Text:" styleClass="label-muted"/>
                                    <TextArea fx:id="textOcrResult" editable="false" prefRowCount="3"
                                              promptText="Chụp vùng để OCR..." styleClass="text-area-dark"/>
                                    <Button fx:id="btnCapture" text="📸 Chụp &amp; OCR" styleClass="btn-secondary" onAction="#onCaptureOcr"/>
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS" alignment="CENTER">
                                    <ImageView fx:id="previewImage" fitWidth="300" fitHeight="180" preserveRatio="true"
                                               styleClass="preview-frame"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Quick Actions Card -->
                        <VBox styleClass="card">
                            <Label text="Quick Actions" styleClass="card-title"/>
                            <HBox spacing="10" alignment="CENTER">
                                <Button fx:id="btnRun" text="▶ Chạy" styleClass="btn-run" onAction="#onRun" minWidth="100"/>
                                <Button fx:id="btnPause" text="⏸ Tạm dừng" styleClass="btn-pause" onAction="#onPause" minWidth="110"/>
                                <Button fx:id="btnStop" text="⏹ Dừng" styleClass="btn-stop" onAction="#onStop" minWidth="100"/>
                                <Separator orientation="VERTICAL" styleClass="sep"/>
                                <Button fx:id="btnRecord" text="🔴 Ghi Macro" styleClass="btn-record" onAction="#onRecord" minWidth="120"/>
                                <Button fx:id="btnOpenScript" text="📂 Mở Script" styleClass="btn-secondary" onAction="#onOpenScript" minWidth="110"/>
                            </HBox>
                        </VBox>

                        <!-- License Card -->
                        <VBox styleClass="card">
                            <Label text="🔑 Kích Hoạt Bản Quyền" styleClass="card-title"/>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="HWID:" styleClass="label-muted"/>
                                <Label fx:id="labelHwid" text="Đang tải..." styleClass="label-mono hwid-label"/>
                                <Button fx:id="btnCopyHwid" text="📋 Copy" styleClass="btn-mini" onAction="#onCopyHwid"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <TextField fx:id="fieldLicenseKey" promptText="Nhập license key tại đây..."
                                           styleClass="text-field-dark" HBox.hgrow="ALWAYS"/>
                                <Button fx:id="btnActivate" text="✅ Kích hoạt" styleClass="btn-activate" onAction="#onActivate"/>
                            </HBox>
                            <Label fx:id="labelLicenseInfo" text="" styleClass="license-info"/>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </Tab>

            <!-- TAB: Macro -->
            <Tab text="🎙️ Macro" fx:id="tabMacro">
                <ScrollPane fitToWidth="true" styleClass="scroll-dark">
                <VBox spacing="12" styleClass="tab-content">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button fx:id="btnMacroRecord" text="🔴 Bắt đầu ghi" styleClass="btn-record" onAction="#onMacroRecord" minWidth="140"/>
                        <Button fx:id="btnMacroStop" text="⏹ Dừng ghi" styleClass="btn-stop" onAction="#onMacroStopRecord" minWidth="120"/>
                        <Separator orientation="VERTICAL"/>
                        <Button fx:id="btnMacroPlay" text="▶ Phát lại" styleClass="btn-run" onAction="#onMacroPlay" minWidth="110"/>
                        <Button fx:id="btnMacroSave" text="💾 Lưu" styleClass="btn-secondary" onAction="#onMacroSave" minWidth="90"/>
                        <Button fx:id="btnMacroLoad" text="📂 Mở" styleClass="btn-secondary" onAction="#onMacroLoad" minWidth="90"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox spacing="6" alignment="CENTER">
                            <Label text="Tốc độ:" styleClass="label-muted"/>
                            <Slider fx:id="sliderSpeed" min="0.25" max="4.0" value="1.0" showTickLabels="true"
                                    majorTickUnit="1.0" minWidth="140"/>
                            <Label fx:id="labelSpeed" text="1.0x" styleClass="label-mono"/>
                        </HBox>
                    </HBox>

                    <HBox spacing="4" alignment="CENTER_LEFT">
                        <Label text="Script:" styleClass="label-muted"/>
                        <Label fx:id="labelMacroName" text="Chưa có macro" styleClass="label-value"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="labelMacroCount" text="0 hành động" styleClass="label-muted"/>
                    </HBox>

                    <ListView fx:id="listMacroActions" styleClass="list-view-dark" prefHeight="140"/>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Lặp lại:" styleClass="label-muted"/>
                        <Spinner fx:id="spinnerRepeat" min="1" max="9999" initialValue="1"
                                 editable="true" prefWidth="90" styleClass="spinner-dark"/>
                        <CheckBox fx:id="checkLoop" text="Vòng lặp vô tận" styleClass="check-dark"/>
                    </HBox>

                    <!-- ============ COORDINATE PICKER PANEL ============ -->
                    <VBox styleClass="card picker-card" spacing="10">

                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="🎯 Game Coordinate Picker" styleClass="card-title picker-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="labelPickerStatus" text="Sẵn sàng" styleClass="picker-status"/>
                        </HBox>
                        <Label text="Di chuột lên nút/ô trong cửa sổ game, nhấn [Bắt tọa độ] để ghi lại (X, Y, màu pixel, nhãn). Sau đó gửi thẳng sang Game Bot." styleClass="label-muted" wrapText="true"/>

                        <!-- Input row -->
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Tên nút:" styleClass="label-muted"/>
                            <TextField fx:id="fieldPickerLabel" promptText="VD: Nút PLAY, Ô username, Nút Login..."
                                       styleClass="text-field-dark" HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnPickerCapture" text="🎯 Bắt tọa độ (3s)"
                                    styleClass="btn-picker-capture" onAction="#onPickerCapture" minWidth="150"/>
                            <Button fx:id="btnPickerContinuous" text="⚡ Liên tục (5s)"
                                    styleClass="btn-picker-continuous" onAction="#onPickerCaptureContinuous" minWidth="130"/>
                        </HBox>

                        <!-- TableView -->
                        <TableView fx:id="tableCoords" styleClass="table-coords"
                                   minHeight="200" prefHeight="220" editable="false">
                            <columns>
                                <TableColumn fx:id="colIndex" text="#" prefWidth="36" minWidth="36" maxWidth="50" sortable="false"/>
                                <TableColumn fx:id="colX" text="X" prefWidth="68" sortable="false"/>
                                <TableColumn fx:id="colY" text="Y" prefWidth="68" sortable="false"/>
                                <TableColumn fx:id="colColor" text="Màu Pixel" prefWidth="130" sortable="false"/>
                                <TableColumn fx:id="colLabel" text="Tên / Nhãn nút" prefWidth="250" sortable="false"/>
                                <TableColumn fx:id="colTime" text="Thời gian" prefWidth="80" sortable="false"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>

                        <!-- Bottom actions row -->
                        <HBox spacing="8" alignment="CENTER_LEFT">

                            <!-- Preview màu của entry đang chọn -->
                            <Label text="Pixel:" styleClass="label-muted"/>
                            <Pane fx:id="paneSelectedColor" prefWidth="22" prefHeight="22"
                                  styleClass="picker-color-preview"/>
                            <Label fx:id="labelSelectedHex" text="#------" styleClass="label-mono"/>

                            <Separator orientation="VERTICAL" styleClass="sep"/>

                            <!-- Table management -->
                            <Button fx:id="btnDeleteEntry" text="🗑 Xóa dòng"
                                    styleClass="btn-mini" onAction="#onPickerDeleteEntry"/>
                            <Button fx:id="btnClearAll" text="🧹 Xóa tất cả"
                                    styleClass="btn-mini" onAction="#onPickerClearAll"/>
                            <Button fx:id="btnCopyJson" text="📋 Copy JSON"
                                    styleClass="btn-mini btn-copy-json" onAction="#onPickerCopyJson"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <!-- Send to Game Bot -->
                            <Label text="Gửi →" styleClass="label-muted"/>
                            <ComboBox fx:id="comboSendTarget" styleClass="combo-dark"
                                      prefWidth="210"/>
                            <Button fx:id="btnSendToBot" text="➡ Gửi sang Game Bot"
                                    styleClass="btn-send-to-bot" onAction="#onPickerSendToBot" minWidth="160"/>
                        </HBox>

                    </VBox>
                    <!-- ============ END COORDINATE PICKER PANEL ============ -->

                </VBox>
                </ScrollPane>
            </Tab>

            <!-- TAB: Settings -->
            <Tab text="⚙️ Cài đặt" fx:id="tabSettings">
                <ScrollPane fitToWidth="true" styleClass="scroll-dark">
                    <VBox spacing="16" styleClass="tab-content">

                        <VBox styleClass="card">
                            <Label text="Phím tắt toàn cục" styleClass="card-title"/>
                            <GridPane hgap="16" vgap="10">
                                <Label text="Chạy / Dừng:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <ComboBox fx:id="comboHotkeyRun" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="combo-dark"/>
                                <Label text="Ghi Macro:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <ComboBox fx:id="comboHotkeyRecord" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="combo-dark"/>
                                <Label text="Dừng khẩn cấp:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <ComboBox fx:id="comboHotkeyEmergency" GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="combo-dark"/>
                            </GridPane>
                            <Button text="💾 Lưu phím tắt" styleClass="btn-secondary" onAction="#onSaveHotkeys"/>
                        </VBox>

                        <VBox styleClass="card">
                            <Label text="Robot Settings" styleClass="card-title"/>
                            <GridPane hgap="16" vgap="10">
                                <Label text="Độ trễ giữa hành động (ms):" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Spinner fx:id="spinnerActionDelay" min="0" max="5000" initialValue="50"
                                         editable="true" prefWidth="100" styleClass="spinner-dark"
                                         GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label text="OCR Language:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <ComboBox fx:id="comboOcrLang" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="combo-dark"/>
                                <Label text="Tessdata path:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <HBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <TextField fx:id="fieldTessPath" text="tessdata" styleClass="text-field-dark" prefWidth="200"/>
                                    <Button text="📂" styleClass="btn-mini" onAction="#onBrowseTessdata"/>
                                </HBox>
                            </GridPane>
                            <Button text="💾 Lưu cài đặt" styleClass="btn-secondary" onAction="#onSaveSettings"/>
                        </VBox>

                        <VBox styleClass="card">
                            <Label text="Thông tin ứng dụng" styleClass="card-title"/>
                            <Label text="JavaRPA Tool v1.0.0" styleClass="label-value"/>
                            <Label text="Build on Java 21 + JavaFX 21" styleClass="label-muted"/>
                            <Label text="© 2024 JavaRPA. Dành cho mục đích thí nghiệm / học tập." styleClass="label-muted"/>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </Tab>

            <!-- TAB: Game Bot -->
            <Tab text="🎮 Game Bot" fx:id="tabGameBot">
                <fx:define>
                    <!-- GameBotController được tạo và inject bởi MainController -->
                </fx:define>
                <ScrollPane fitToWidth="true" styleClass="scroll-dark">
                    <HBox spacing="12" styleClass="tab-content" alignment="TOP_LEFT">

                        <!-- ======= CỘT TRÁI: Profile Setup (compact) ======= -->
                        <VBox spacing="10" prefWidth="250" minWidth="230" maxWidth="270">

                            <!-- Profile Selector -->
                            <VBox styleClass="card" spacing="8">
                                <Label text="📋 Profile" styleClass="card-title"/>
                                <ComboBox fx:id="comboProfiles" maxWidth="Infinity" styleClass="combo-dark"
                                          promptText="-- Chọn profile --"/>
                                <HBox spacing="6">
                                    <Button text="➕ Mới" styleClass="btn-mini" onAction="#onNewProfile" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                    <Button text="🗑 Xóa" styleClass="btn-mini" onAction="#onDeleteProfile" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                </HBox>
                            </VBox>

                            <!-- Game Info -->
                            <VBox styleClass="card" spacing="6">
                                <Label text="🎮 Game" styleClass="card-title"/>

                                <Label text="Tên Profile:" styleClass="label-muted"/>
                                <TextField fx:id="fieldProfileName" promptText="VD: CF Acc1" styleClass="text-field-dark"/>

                                <Label text="Đường dẫn .exe:" styleClass="label-muted"/>
                                <HBox spacing="6">
                                    <TextField fx:id="fieldExePath" promptText="C:\Game\launcher.exe"
                                               styleClass="text-field-dark" HBox.hgrow="ALWAYS"/>
                                    <Button text="📂" styleClass="btn-mini" onAction="#onBrowseExe"/>
                                </HBox>

                                <!-- Tên Game (ẩn label, dùng field nhỏ gọn) -->
                                <TextField fx:id="fieldGameName" promptText="Tên game (VD: CrossFire)" styleClass="text-field-dark" visible="false" managed="false"/>
                            </VBox>

                            <!-- Account -->
                            <VBox styleClass="card" spacing="6">
                                <Label text="🔑 Tài Khoản" styleClass="card-title"/>

                                <Label text="Username:" styleClass="label-muted"/>
                                <TextField fx:id="fieldUsername" promptText="Tên đăng nhập" styleClass="text-field-dark"/>

                                <Label text="Mật khẩu:" styleClass="label-muted"/>
                                <PasswordField fx:id="fieldPassword" promptText="••••••••" styleClass="text-field-dark"/>

                                <Label text="Máy chủ:" styleClass="label-muted"/>
                                <ComboBox fx:id="comboChannel" maxWidth="Infinity" styleClass="combo-dark"
                                          promptText="-- Chọn máy chủ --"/>

                                <Label text="Kênh:" styleClass="label-muted"/>
                                <ComboBox fx:id="comboChannelNumber" maxWidth="Infinity" styleClass="combo-dark"
                                          promptText="-- Chọn kênh --"/>
                            </VBox>

                            <!-- Save button -->
                            <Button text="💾 Lưu Profile" styleClass="btn-activate" onAction="#onSaveProfile" maxWidth="Infinity"/>

                        </VBox>

                        <!-- ======= CỘT GIỮA: Ẩn hoàn toàn (giữ FXML bindings) ======= -->
                        <VBox spacing="10" visible="false" managed="false">

                            <!-- UI Coordinates (ẩn — đã có tọa độ mặc định) -->
                            <VBox styleClass="card" spacing="8" visible="false" managed="false">
                                <Label text="📍 Toạ Độ UI (Click [Pick] sau đó di chuột vào vị trí cần bắt)" styleClass="card-title"/>
                                <Label text="Sau 3 giây đếm ngược, toạ độ chuột sẽ tự động được lưu." styleClass="label-muted" wrapText="true"/>

                                <!-- Row helper macro -->
                                <GridPane hgap="6" vgap="6">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="100" prefWidth="110"/>
                                        <ColumnConstraints prefWidth="60"/>
                                        <ColumnConstraints prefWidth="60"/>
                                        <ColumnConstraints prefWidth="55"/>
                                    </columnConstraints>

                                    <!-- Header row -->
                                    <Label text="Vị trí"   styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                    <Label text="X"        styleClass="label-muted" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                    <Label text="Y"        styleClass="label-muted" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                                    <!-- Username -->
                                    <Label text="Ô Username:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                    <TextField fx:id="fieldUsernameX" styleClass="text-field-dark coord-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                    <TextField fx:id="fieldUsernameY" styleClass="text-field-dark coord-field" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                    <Button text="📍" styleClass="btn-mini pick-btn" onAction="#onPickUsername" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                                    <!-- Password -->
                                    <Label text="Ô Password:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                    <TextField fx:id="fieldPasswordX" styleClass="text-field-dark coord-field" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                    <TextField fx:id="fieldPasswordY" styleClass="text-field-dark coord-field" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                                    <Button text="📍" styleClass="btn-mini pick-btn" onAction="#onPickPassword" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                                    <!-- Login button -->
                                    <Label text="Nút Đăng nhập:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                    <TextField fx:id="fieldLoginBtnX" styleClass="text-field-dark coord-field" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                    <TextField fx:id="fieldLoginBtnY" styleClass="text-field-dark coord-field" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                                    <Button text="📍" styleClass="btn-mini pick-btn" onAction="#onPickLoginBtn" GridPane.columnIndex="3" GridPane.rowIndex="3"/>

                                    <!-- Server -->
                                    <Label text="Click Server:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                    <TextField fx:id="fieldServerX" styleClass="text-field-dark coord-field" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                                    <TextField fx:id="fieldServerY" styleClass="text-field-dark coord-field" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
                                    <Button text="📍" styleClass="btn-mini pick-btn" onAction="#onPickServer" GridPane.columnIndex="3" GridPane.rowIndex="4"/>

                                    <!-- Enter game -->
                                    <Label text="Nút Vào Game:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                                    <TextField fx:id="fieldEnterGameX" styleClass="text-field-dark coord-field" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                                    <TextField fx:id="fieldEnterGameY" styleClass="text-field-dark coord-field" GridPane.columnIndex="2" GridPane.rowIndex="5"/>
                                    <Button text="📍" styleClass="btn-mini pick-btn" onAction="#onPickEnterGame" GridPane.columnIndex="3" GridPane.rowIndex="5"/>
                                </GridPane>
                            </VBox>

                            <!-- Pixel Detect (ẩn — auto-detect thay thế) -->
                            <VBox styleClass="card" spacing="8" visible="false" managed="false">
                                <Label text="🔍 Pixel Detect (Chờ màn hình xuất hiện)" styleClass="card-title"/>
                                <Label text="Bot sẽ chờ đúng màu pixel tại toạ độ này trước khi tiến hành bước tiếp theo." styleClass="label-muted" wrapText="true"/>

                                <GridPane hgap="6" vgap="6">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="100" prefWidth="105"/>
                                        <ColumnConstraints prefWidth="52"/>
                                        <ColumnConstraints prefWidth="52"/>
                                        <ColumnConstraints prefWidth="70"/>
                                        <ColumnConstraints prefWidth="45"/>
                                    </columnConstraints>

                                    <Label text="Màn hình" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                    <Label text="X"        styleClass="label-muted" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                    <Label text="Y"        styleClass="label-muted" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                    <Label text="Màu HEX"  styleClass="label-muted" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                                    <!-- Login detect -->
                                    <Label text="Login Screen:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                    <TextField fx:id="fieldLoginDetectX" styleClass="text-field-dark coord-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                    <TextField fx:id="fieldLoginDetectY" styleClass="text-field-dark coord-field" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                    <TextField fx:id="fieldLoginDetectHex" styleClass="text-field-dark" promptText="#FFFFFF" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                                    <Button text="📍" styleClass="btn-mini pick-btn" onAction="#onPickLoginDetect" GridPane.columnIndex="4" GridPane.rowIndex="1"/>

                                    <!-- Server detect -->
                                    <Label text="Server Screen:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                    <TextField fx:id="fieldServerDetectX" styleClass="text-field-dark coord-field" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                    <TextField fx:id="fieldServerDetectY" styleClass="text-field-dark coord-field" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                                    <TextField fx:id="fieldServerDetectHex" styleClass="text-field-dark" promptText="#FFFFFF" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                                    <Button text="📍" styleClass="btn-mini pick-btn" onAction="#onPickServerDetect" GridPane.columnIndex="4" GridPane.rowIndex="2"/>
                                </GridPane>

                                <!-- Template matching: chụp mẫu login screen -->
                                <Label text="📸 Template Matching (chính xác nhất):" styleClass="label-muted" style="-fx-font-weight: bold;"/>
                                <Label text="Mở game → đến màn hình login → nhấn nút dưới để chụp mẫu. Bot sẽ so sánh ảnh để biết chính xác login screen đã hiện chưa." styleClass="label-muted" wrapText="true" style="-fx-font-size: 10;"/>
                                <Button text="📸 Chụp mẫu Login Screen" styleClass="btn-activate"
                                        onAction="#onCaptureLoginRef" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Bot settings (ẩn — dùng giá trị mặc định) -->
                            <VBox styleClass="card" spacing="8" visible="false" managed="false">
                                <Label text="⚙️ Cài Đặt Bot" styleClass="card-title"/>
                                <GridPane hgap="12" vgap="8">
                                    <Label text="Delay mỗi bước (ms):" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                    <Spinner fx:id="spinnerStepDelay" editable="true" prefWidth="100"
                                             styleClass="spinner-dark" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                    <Label text="Timeout chờ (ms):" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                    <Spinner fx:id="spinnerWaitTimeout" editable="true" prefWidth="100"
                                             styleClass="spinner-dark" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                    <Label text="Chờ sau khi mở exe (ms):" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                    <Spinner fx:id="spinnerLaunchWait" editable="true" prefWidth="100"
                                             styleClass="spinner-dark" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                </GridPane>
                                <CheckBox fx:id="checkRunAsAdmin" text="🛡 Mở game với quyền Admin (Run as Administrator)" styleClass="check-dark"/>
                                <CheckBox fx:id="checkAutoReconnect" text="🔄 Tự động reconnect khi disconnect" styleClass="check-dark"/>
                            </VBox>

                        </VBox>

                        <!-- ======= CỘT PHẢI: Bot Control + Log (ưu tiên) ======= -->
                        <VBox spacing="10" HBox.hgrow="ALWAYS">

                            <!-- Control — compact -->
                            <VBox styleClass="card" spacing="8">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="🚀 Bot" styleClass="card-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="Trạng thái:" styleClass="label-muted"/>
                                    <Label fx:id="labelBotState" text="⏸ Chờ" styleClass="label-value"/>
                                </HBox>

                                <HBox spacing="8" alignment="CENTER">
                                    <Button fx:id="btnStartBot" text="▶ Bắt đầu Bot" styleClass="btn-run"
                                            onAction="#onStartBot" minWidth="130"/>
                                    <Button fx:id="btnPauseBot" text="⏸ Tạm dừng" styleClass="btn-pause"
                                            onAction="#onPauseBot" minWidth="110" disable="true"/>
                                    <Button fx:id="btnStopBot" text="⏹ Dừng Bot" styleClass="btn-stop"
                                            onAction="#onStopBot" minWidth="110" disable="true"/>
                                </HBox>
                            </VBox>

                            <!-- Log — chiếm toàn bộ không gian còn lại -->
                            <VBox styleClass="card" spacing="8" VBox.vgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="📄 Log Bot" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                                    <Button text="🗑 Xóa log" styleClass="btn-mini" onAction="#onClearLog"/>
                                </HBox>
                                <TextArea fx:id="textBotLog" editable="false" prefRowCount="30"
                                          wrapText="true" styleClass="text-area-dark" VBox.vgrow="ALWAYS"
                                          style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 11;"/>
                            </VBox>

                        </VBox>

                    </HBox>
                </ScrollPane>
            </Tab>

        </TabPane>
    </center>

    <!-- BOTTOM STATUS BAR -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="20">
            <Label text="F6: Chạy/Dừng" styleClass="hotkey-hint"/>
            <Label text="F7: Ghi Macro" styleClass="hotkey-hint"/>
            <Label text="F8: Dừng khẩn cấp" styleClass="hotkey-hint"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="labelLog" text="Sẵn sàng" styleClass="log-label"/>
        </HBox>
    </bottom>

</BorderPane>
